# ================================================================
# chatplatform — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ================================================================

# PostgreSQL
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_PASSWORD=changeme_redis_password

# RabbitMQ
RABBITMQ_PASSWORD=changeme_rabbitmq_password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password

# JWT Authentication (shared secret across all services — min 32 chars)
JWT_SECRET=changeme_super_secret_jwt_key_minimum_32_characters_long

# Application
ENCRYPTION_KEY=changeme_32_byte_hex_key_here_0000

# Grafana
GRAFANA_PASSWORD=changeme_grafana_password

# n8n (optional)
N8N_PASSWORD=changeme_n8n_password

# WAHA WhatsApp (optional)
WAHA_API_KEY=changeme_waha_key

# App URLs
APP_DOMAIN=yourdomain.com
API_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
